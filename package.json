{
  "name": "agentarena-superteam-infra-v3",
  "version": "3.0.0",
  "description": "First-place-quality Solana smart transaction stack for the Superteam Advanced Infrastructure Challenge: SolInfra-powered Yellowstone/Geyser streaming, official jito-ts bundle submission, dynamic tip intelligence, LLM-backed AI timing/tip/retry decisions, fault injection, and judge-verifiable lifecycle evidence.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "watch:slots": "tsx src/cli/watch-slots.ts",
    "watch:pumpfun": "tsx src/cli/watch-pumpfun.ts",
    "challenge:dashboard": "tsx src/cli/dashboard.ts",
    "challenge:run": "tsx src/cli/run-challenge.ts",
    "challenge:score": "tsx src/cli/score-self.ts",
    "challenge:export-evidence": "tsx src/cli/export-evidence.ts",
    "test:fault-expiry": "tsx src/cli/run-challenge.ts --count 1 --failures 1 --fault expired_blockhash",
    "lint:types": "tsc --noEmit",
    "format": "prettier --write .",
    "preflight": "tsx src/cli/preflight.ts",
    "challenge:first-place": "tsx src/cli/first-place-run.ts",
    "challenge:verify-evidence": "tsx src/cli/verify-evidence.ts",
    "challenge:reset-evidence": "tsx src/cli/reset-evidence.ts",
    "challenge:doctor": "tsx src/cli/doctor.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@solana/web3.js": "^1.98.0",
    "@triton-one/yellowstone-grpc": "^1.3.0",
    "bs58": "^6.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "jito-ts": "^4.2.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
