# ============================================================================
# AgentArena Smart Transaction Stack — environment
# Infrastructure sponsor: SolInfra (RPC nodes + Yellowstone gRPC access).
# Copy to .env and fill in your SolInfra credentials + payer keypair.
# ============================================================================

# Cluster
TARGET_CLUSTER=mainnet-beta

# --- SolInfra RPC + WebSocket (sponsor) ---
SOLANA_RPC_URL=https://YOUR_SOLINFRA_RPC
SOLANA_WS_URL=wss://YOUR_SOLINFRA_WS

# --- SolInfra Yellowstone / Geyser gRPC (sponsor) ---
YELLOWSTONE_GRPC_URL=https://YOUR_SOLINFRA_YELLOWSTONE_GRPC
YELLOWSTONE_TOKEN=YOUR_TOKEN_IF_REQUIRED
YELLOWSTONE_COMMITMENT=processed
GEYSER_PING_INTERVAL_MS=15000
GEYSER_MAX_BUFFERED_EVENTS=20000

# --- Jito block engine ---
# JITO_TRANSPORT=grpc uses the official jito-ts SDK (recommended). Set to jsonrpc to use the
# dependency-light HTTP transport if gRPC is unavailable in your environment.
JITO_TRANSPORT=jsonrpc
JITO_BLOCK_ENGINE_URL=https://frankfurt.mainnet.block-engine.jito.wtf
# Optional explicit gRPC host (no scheme). Leave blank to derive from JITO_BLOCK_ENGINE_URL.
JITO_BLOCK_ENGINE_GRPC_URL=
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor
JITO_AUTH_UUID=
# Optional searcher auth keypair for gRPC (path to a Solana keypair JSON). Blank = public access.
JITO_AUTH_KEYPATH=
JITO_REGION=mainnet
JITO_LEADER_WINDOW_MAX_SLOTS=3
JITO_LEADER_HOLD_MAX_MS=15000

# --- Payer ---
KEYPAIR_PATH=./keys/payer.json

# --- Tip policy (guardrails only; final tips are chosen dynamically from live data) ---
TIP_MIN_LAMPORTS=200000
TIP_MAX_LAMPORTS=2000000
TIP_PERCENTILE_TARGET=90
TIP_CONGESTION_MULTIPLIER_MAX=2.25
PRIORITY_FEE_MICROLAMPORTS=3000000
BLOCKHASH_COMMITMENT=confirmed

# --- Lifecycle windows ---
LIFECYCLE_TIMEOUT_MS=45000
CONFIRMED_TIMEOUT_MS=30000
FINALIZED_TIMEOUT_MS=60000
# Confirm landing from the Yellowstone slot-status stream (true) in addition to the RPC signature
# subscription. RPC polling is never used.
USE_STREAM_COMMITMENT=true
EVIDENCE_DIR=./evidence

# --- AI agent ---
# llm   = Anthropic Claude owns the operational decision (recommended; reasoning is visible).
# heuristic = fully self-contained deterministic engine (no external API, used as fallback).
AI_DECISION_MODE=llm
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_LLM_TIMEOUT_MS=30000
AI_LLM_MAX_TOKENS=1024
AI_RISK_TOLERANCE=balanced
AI_MAX_RETRY_ATTEMPTS=2
AI_ALLOW_HOLD=true
AI_MIN_LANDING_PROBABILITY=0.72

# --- First-place scoring gate ---
PUBLIC_ARCHITECTURE_URL=
FIRST_PLACE_MIN_SCORE=94
FIRST_PLACE_TARGET_RECORDS=25
FIRST_PLACE_TARGET_FAILURES=5
REQUIRE_PUBLIC_ARCHITECTURE_URL_FOR_SCORE=true

# --- Real live-event source (pump.fun trades decoded from Yellowstone gRPC) ---
# When true, each bundle is triggered by a real on-chain pump.fun trade and the event is recorded
# in the evidence. Read-only — the stack never trades. Set false for a self-driven loop.
REACT_TO_LIVE_EVENTS=true
PUMPFUN_PROGRAM_ID=6EF8rrecthR5Dkzon8Nwu78hRvfCKubJ14M5uBEwF6P
PUMPFUN_EVENT_TIMEOUT_MS=20000

# --- Demo payload ---
DEMO_MEMO_PREFIX=AgentArena-Superteam-Bundle
DEMO_BUNDLE_TX_COUNT=1

# --- Local testing only. Do not submit dry-run evidence. ---
ALLOW_DRY_RUN=false
ALLOW_EXAMPLE_EVIDENCE=false
